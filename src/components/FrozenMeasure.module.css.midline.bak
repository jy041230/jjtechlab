.container {
  position: relative;
  width: 100%;
  height: 100%;
  background: #111;
  overflow: hidden;
}

/* 단일 캔버스 — 이미지(cover) + 오버레이 통합 렌더링 */
.canvas {
  display: block;
  width: 100%;
  height: 100%;
  touch-action: none;
}

.tapCursor { cursor: crosshair; }

.zoomControls {
  position: absolute;
  right: 12px;
  top: 18px;
  z-index: 2000;
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: center;
}

.zoomTitle {
  background: rgba(255, 255, 255, 0.92);
  color: #1b4332;
  font-size: 12px;
  font-weight: 900;
  padding: 5px 8px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.zoomControls button {
  width: 62px;
  height: 54px;
  border-radius: 16px;
  border: 0;
  background: rgba(45,106,79,0.94);
  color: #fff;
  font-size: 22px;
  font-weight: 900;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.zoomControls .autoFitBtn {
  background: rgba(255,107,53,0.96);
  font-size: 17px;
  line-height: 1.05;
}

.zoomControls .stickerFitBtn {
  background: rgba(30, 144, 255, 0.96);
  font-size: 16px;
  line-height: 1.05;
}

.panHint {
  position: absolute;
  top: 86px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1999;
  background: rgba(0,0,0,0.68);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  padding: 7px 12px;
  border-radius: 16px;
  pointer-events: none;
}

/* 마커 인식 실패 오버레이 */
.noMarkerOverlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  text-align: center;
  padding: 24px;
  pointer-events: none;
}
.noMarkerIcon { font-size: 48px; }
.noMarkerOverlay p { font-size: 18px; font-weight: 700; }
.noMarkerSub { font-size: 15px; opacity: 0.75; font-weight: 400; }

/* 디버그 정보 박스 */
.debugBox {
  margin-top: 12px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 10px;
  padding: 10px 14px;
  text-align: left;
  width: 100%;
  max-width: 320px;
}
.debugBox p { font-size: 13px; font-weight: 400; opacity: 0.9; margin: 2px 0; }
.debugBox strong { font-weight: 800; color: #ffd166; }
.debugDicts { font-size: 12px; opacity: 0.65; }
.debugTip { font-size: 13px; color: #ffd166; margin-top: 6px !important; }

/* 탭 안내 힌트 — 하단 */
.hint {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.7);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  padding: 8px 20px;
  border-radius: 22px;
  white-space: nowrap;
  pointer-events: none;
  backdrop-filter: blur(4px);
}

.hintTap {
  background: rgba(255, 107, 53, 0.9);
  animation: blink 1.4s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.72; }
}
