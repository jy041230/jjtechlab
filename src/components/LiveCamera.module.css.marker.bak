.container {
  position: relative;
  width: 100%;
  height: 100%;
  background: #000;
  overflow: hidden;
}

.fileInput {
  display: none;
}

/* 라이브 영상: 가로폭 꽉 채움 */
.video {
  width: 100%;
  height: 100%;
  object-fit: cover;   /* 꽉 채우기 — 좌표 변환 불필요(캡처는 full-res canvas) */
  display: block;
}

.playOverlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 0;
  background: rgba(0,0,0,0.65);
  color: #fff;
  text-align: center;
  padding: 24px;
}

.playOverlay span {
  font-size: 22px;
  font-weight: 800;
}

.playOverlay small {
  font-size: 15px;
  line-height: 1.5;
  opacity: 0.9;
}

.playOverlay em {
  display: block;
  max-width: 86%;
  margin-top: 8px;
  color: #ffd166;
  font-size: 12px;
  font-style: normal;
  line-height: 1.45;
  word-break: break-word;
}

.retryBtn {
  margin-top: 10px;
  min-height: 48px;
  border-radius: 24px;
  border: 0;
  background: #2d6a4f;
  color: #fff;
  font-size: 16px;
  font-weight: 800;
  padding: 0 22px;
}

.fileBtn {
  min-height: 48px;
  border-radius: 24px;
  border: 2px solid rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.12);
  color: #fff;
  font-size: 16px;
  font-weight: 800;
  padding: 0 22px;
}

.debugBadge {
  display: none;
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 12;
  background: rgba(0,0,0,0.62);
  color: #b7ffbf;
  font-family: monospace;
  font-size: 11px;
  padding: 5px 8px;
  border-radius: 8px;
  pointer-events: none;
}

/* 안내 문구 — 상단 */
.hint {
  position: absolute;
  top: 12px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  padding: 6px 16px;
  border-radius: 20px;
  white-space: nowrap;
  pointer-events: none;
  backdrop-filter: blur(4px);
  z-index: 10;
}

/* 셔터 버튼 — iOS Camera 스타일 */
.shutter {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  width: 72px;
  height: 72px;
  min-width: 72px;
  min-height: 72px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 3px solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  backdrop-filter: blur(4px);
  z-index: 15;
}

.shutter:active { transform: translateX(-50%) scale(0.92); }

.shutterInner {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #fff;
  display: block;
}

/* 닫기 버튼 — 우상단 */
.closeBtn {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 40px;
  height: 40px;
  min-width: 40px;
  min-height: 40px;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  backdrop-filter: blur(4px);
  z-index: 16;
}
